# =============================================
# Mavicure Travel Tours — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# =============================================

# Supabase (get from https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Wompi — Colombia (Bancolombia) domestic payments: cards, PSE, Nequi, Daviplata
# Register at https://comercios.wompi.co → Desarrolladores
# Test keys: pub_test_ / prv_test_ | Production: pub_prod_ / prv_prod_
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_KEY=test_integrity_xxxxxxxxxxxxxxxx
WOMPI_EVENTS_KEY=test_events_xxxxxxxxxxxxxxxxxxxxxxx

# PayU — Colombia (cards + Efecty + Baloto + PSE + international)
# Register at https://www.payulatam.com → Módulo administrativo
# Test credentials: https://developers.payulatam.com/latam/en/docs/getting-started/test-your-solution.html
PAYU_MERCHANT_ID=508029
PAYU_ACCOUNT_ID=512321
PAYU_API_KEY=4Vj8eK4rloUd272L48hsrarnUA
PAYU_API_LOGIN=pRRXKOl8ikMmt9u
NEXT_PUBLIC_PAYU_TEST=true

# Mercado Pago — Latin American + international cards, installments
# Register at https://www.mercadopago.com.co/developers
# Test credentials from: Dashboard → Credentials → Test
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PayPal — International payments (USD/EUR), non-LA clients
# Register at https://developer.paypal.com → Apps & Credentials
# Sandbox: create test app | Production: use live credentials
PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=EHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_ENV=sandbox

# COP → USD conversion rate for PayPal (update periodically)
# Check current rate at https://www.banrep.gov.co/es/tasa-de-cambio-del-peso-colombiano-trm
PAYPAL_COP_TO_USD_RATE=4100

# Email (Resend) — https://resend.com → free tier: 3,000 emails/month
# Verify your domain in Resend dashboard first
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=reservas@mavicuretravel.com

# Your deployed site URL (used for payment redirect URLs)
NEXT_PUBLIC_SITE_URL=https://mavicuretours.vercel.app
